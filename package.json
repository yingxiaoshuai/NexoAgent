{
  "name": "nexo-agent",
  "version": "0.0.4",
  "private": true,
  "description": "Nexo Agent desktop and web console built with Electron, React, TypeScript, and Ant Design.",
  "main": "dist-electron/electron/bootstrap.js",
  "scripts": {
    "dev:web": "vite --host 0.0.0.0",
    "dev:electron": "concurrently -k \"npm:dev:web\" \"npm:dev:electron:watch\" \"npm:dev:electron:start\"",
    "dev:electron:watch": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron:start": "wait-on tcp:8106 file:dist-electron/electron/bootstrap.js file:dist-electron/electron/main.js file:dist-electron/electron/preload.js && cross-env VITE_DEV_SERVER_URL=http://localhost:8106 electron .",
    "icons:build": "node scripts/generate-icons.mjs",
    "build:web": "tsc -p tsconfig.json --noEmit && vite build",
    "build:electron": "node -e \"require('node:fs').rmSync('dist-electron', { recursive: true, force: true })\" && tsc -p tsconfig.electron.json",
    "build": "npm run build:web && npm run build:electron",
    "dist:win": "electron-builder --publish never --win nsis zip",
    "dist:mac": "electron-builder --publish never --mac dmg zip",
    "dist:linux": "electron-builder --publish never --linux AppImage tar.gz",
    "package:win": "npm run build && npm run dist:win",
    "package:mac": "npm run build && npm run dist:mac",
    "package:linux": "npm run build && npm run dist:linux",
    "serve:web-console": "node dist-electron/electron/standalone.js",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "verify:context-management": "npm run build:electron && node scripts/verify-context-management.mjs",
    "verify:provider-embeddings": "npm run build:electron && node scripts/verify-provider-embeddings.mjs",
    "verify:multimodal-models": "npm run build:electron && node scripts/verify-multimodal-models.mjs",
    "package": "npm run build && electron-builder --publish never"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@langchain/core": "^1.2.1",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.5.2",
    "@types/sql.js": "^1.4.11",
    "antd": "^5.22.5",
    "busboy": "^1.6.0",
    "chromadb": "^3.4.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "langchain": "^1.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.28.0",
    "rehype-highlight": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "sql.js": "^1.14.1",
    "uuid": "^11.0.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/busboy": "^1.5.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.company.nexoagent",
    "productName": "Nexo Agent",
    "icon": "assets/nexoagent-icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "nexo/**/*",
      "assets/nexoagent-icon.png",
      "assets/nexoagent-icon.ico",
      "node_modules/sql.js/dist/sql-wasm.wasm",
      "package.json"
    ],
    "win": {
      "icon": "assets/nexoagent-icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "icon": "assets/nexoagent-icon.png",
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/nexoagent-icon.ico",
      "uninstallerIcon": "assets/nexoagent-icon.ico",
      "installerHeaderIcon": "assets/nexoagent-icon.ico"
    }
  }
}
